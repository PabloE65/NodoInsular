---
import { Image } from 'astro:assets';
import playaHero from '../../images/playa_hero.webp';
---

<section id="trabajos" class="relative py-24 px-6 overflow-hidden">
  <Image
    src={playaHero}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    widths={[800, 1200, 1920]}
    sizes="100vw"
  />
  <div class="absolute inset-0 bg-cornsilk-50/85"></div>
  <div class="relative z-10 max-w-6xl mx-auto">
    <div class="flex flex-col items-center mb-14">
      <span class="text-xs bg-sunlit-clay-500/10 text-sunlit-clay-700 border border-sunlit-clay-400/30 rounded-full px-4 py-1 mb-4 uppercase tracking-wider">Próximamente</span>
      <p class="text-olive-leaf-600 text-sm uppercase tracking-widest mb-3">Portafolio</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">Trabajos realizados</h2>
      <p class="text-olive-leaf-700 text-center max-w-xl">
        Aquí iremos publicando los proyectos que construimos junto a nuestros clientes.
        Estamos en nuestros primeros pasos — ¡sé parte de los primeros!
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-6 opacity-40 pointer-events-none select-none">
      {[1, 2, 3].map(() => (
        <div class="bg-cornsilk-100 border border-cornsilk-200 rounded-xl overflow-hidden">
          <div class="h-40 bg-cornsilk-200"></div>
          <div class="p-6">
            <div class="h-3 bg-cornsilk-300 rounded w-1/3 mb-3"></div>
            <div class="h-4 bg-cornsilk-300 rounded w-3/4 mb-2"></div>
            <div class="h-3 bg-cornsilk-200 rounded w-full"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
