---
import { Image } from 'astro:assets';
import bosqueHero from '../../images/bosque_hero.webp';
---

<section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20 overflow-hidden">
  <Image
    src={bosqueHero}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    widths={[800, 1200, 1920]}
    sizes="100vw"
  />
  <div class="absolute inset-0 bg-cornsilk-50/85"></div>

  <div class="relative z-10 flex flex-col items-center">
    <p class="text-sm text-olive-leaf-700 uppercase tracking-widest mb-4 font-semibold">Sur de Chile · Partner Tecnológico Local</p>
    <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6">
      Tu solución digital,<br/>
      <span class="text-olive-leaf-700">Sin complicaciones.</span>
    </h1>
    <p class="text-olive-leaf-700 text-lg max-w-2xl mb-10 text-justify">
    Somos tu partner tecnológico en el <span class="text-copperwood-900 font-medium">Sur Chile</span>. Diseñamos e-commerce, landing pages y <span class="text-copperwood-900 font-medium">webapps a medida</span>, entregando un servicio de <span class="text-copperwood-900 font-medium">soporte continuo</span> diseñado especialmente para pymes o emprendimientos en la <span class="text-copperwood-900 font-medium">Décima región</span>.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="#contacto" class="bg-black-forest-700 hover:bg-black-forest-600 transition-colors px-8 py-3 rounded-lg font-medium text-white">
        Conversemos
      </a>
      <a href="#servicios" class="border border-olive-leaf-400 hover:border-olive-leaf-600 transition-colors px-8 py-3 rounded-lg font-medium text-olive-leaf-800">
        Ver servicios
      </a>
    </div>
  </div>
</section>
