---
import { Font } from "astro:assets";
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nodo Insular — Software a Medida para tu Negocio',
  description = 'Nodo Insular — Desarrollo de software a medida para pequeños negocios en el sur de Chile. Automatización, IA, e-commerce y más.',
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <Font cssVariable="--font-inter" preload />
  </head>
  <body class="bg-cornsilk-50 text-black-forest-950" style="font-family: var(--font-inter), sans-serif;">
    <slot />
    {import.meta.env.PROD && (
      <div id="coming-soon" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-olive-leaf-950/95 backdrop-blur-sm">
        <p class="text-olive-leaf-400 text-sm uppercase tracking-widest mb-4">Nodo Digital</p>
        <h1 class="text-5xl md:text-7xl font-bold text-cornsilk-50 mb-4">Próximamente</h1>
        <p class="text-cornsilk-200 text-lg max-w-sm text-center">Estamos terminando los últimos detalles. Volvemos pronto.</p>
      </div>
    )}
  </body>
</html>
